    <!--약관 Modal 부분 -->
    <div
      class="modal fade"
      id="rulesModal"
      tabindex="-1"
      aria-labelledby="rulesModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <!-- <div class="modal-header">
        모달 헤더부분
        <h5 class="modal-title" id="rulesModalLabel">Modal title</h5>
        <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div> -->
          <div class="modal-body">
            <h1 class="modal-title" id="rulesModalLabel">상담신청 동의안내</h1>
            <button
              type="button"
              class="close"
              data-bs-dismiss="modal"
              aria-label="Close"
            >
              <span aria-hidden="true">&times;</span>
            </button>
            <!-- 전체동의 -->
            <div class="row">
              <div class="col-12 check-all">
                <input id="main-check1" type="checkbox" value="1" /><label
                  for="main-check1"
                  ><span>전체 동의하기</span></label
                >
                <p>
                  ※ 개인정보 수집 및 이용, 마케팅 이용(선택), 개인정보 공유 및
                  제 3자 제공(선택)동의를 포함합니다.
                </p>
              </div>
            </div>

            <!-- 필수 수집동의 -->
            <div class="row m-0">
              <div class="col-12">
                <div class="slideButton rules1">
                  <div class="online-titl-g1">
                    <!-- 약관 타이틀 조회후 생성-->
                  </div>
                  <div class="online-sub-titl-g1">
                    <!-- 약관 서브타이틀 조회후 생성-->
                  </div>
                  <div class="arrowrap">
                    <span class="arrow-left"
                      ><img src="/assets/common/icon_left_arrow_yellow.svg"
                    /></span>
                  </div>
                </div>
              </div>
              <div class="col-12 check-option">
                <span>
                  <input id="main-check2" type="checkbox" value="2" />
                  <label for="main-check2">
                    <span class="online-marker-titl-g1">
                      <!-- 약관 마커타이틀 조회후 생성-->
                    </span>
                  </label>
                </span>
              </div>
            </div>

            <!-- 마케팅 수집동의 -->
            <div class="row m-0">
              <div class="col-12">
                <div class="slideButton rules2">
                  <div class="online-titl-g2">
                    <!-- 약관 타이틀 조회후 생성-->
                  </div>
                  <div class="online-sub-titl-g2">
                    <!-- 약관 서브타이틀 조회후 생성-->
                  </div>
                  <div class="arrowrap">
                    <span class="arrow-left"
                      ><img src="/assets/common/icon_left_arrow_yellow.svg"
                    /></span>
                  </div>
                </div>
              </div>
              <div class="col-12 check-option">
                <input id="main-check3" type="checkbox" value="3" />
                <label for="main-check3">
                  <span class="online-marker-titl-g2">
                    <!-- 약관 마커타이틀 조회후 생성-->
                  </span>
                </label>
              </div>
            </div>

            <!-- 개인정보 공유 -->
            <div class="row m-0">
              <div class="col-12">
                <div class="slideButton rules3">
                  <div class="online-titl-g3">
                    <!-- 약관 타이틀 조회후 생성-->
                  </div>
                  <div class="online-sub-titl-g3">
                    <!-- 약관 서브타이틀 조회후 생성-->
                  </div>
                  <div class="arrowrap">
                    <span class="arrow-left"
                      ><img src="/assets/common/icon_left_arrow_yellow.svg"
                    /></span>
                  </div>
                </div>
              </div>
              <div class="col-12 check-option">
                <input id="main-check4" type="checkbox" value="4" />
                <label for="main-check4">
                  <span class="online-marker-titl-g3">
                    <!-- 약관 마커타이틀 조회후 생성-->
                  </span>
                </label>
              </div>
            </div>

            <div class="row">
              <!-- 상담신청 버튼 -->
              <div class="pop-req-btn">
                <input
                  name="btn-more-then"
                  type="button"
                  value="상담신청하기"
                />
              </div>
            </div>

            <!-- 숨겨진 약관 div -->
            <div id="slideInDiv" class="slide-in-div">
              <div class="online-titl">
                <!-- 약관타이틀 조회후 생성-->
              </div>
              <div>
                <button
                  class="btn-close closeSlideButton"
                  value="X버튼"
                ></button>
              </div>
              <div class="online-conts">
                <!-- 약관내용 조회후 생성-->
              </div>
              <div class="slideInDiv-close">
                <!-- 확인 버튼 -->
                <input class="closeSlideButton" type="button" value="확인" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 공용 알럿 -->
    <div id="overlay" class="overlay"></div>
    <div id="customAlert" class="custom-alert">
      <div class="title" id="alertTitle">타이틀</div>
      <div class="message" id="alertMessage">내용</div>
      <button class="completion-btn" onclick="completionAlert()">확인</button>
      <!-- <button class="close-btn" onclick="closeAlert()">취소</button> -->
    </div>

    <script src="scripts/loan-card.js"></script>

  </body>

