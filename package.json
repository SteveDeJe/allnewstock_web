{
  "name": "hi-homepage-web-allnew",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "npm run copy-config && npm run copy-libs",
    "copy-libs": "cpx \"node_modules/{axios,moment,bootstrap,jquery,swiper}/**/*\" public/node_modules -C",
    "copy-config": "cross-env-shell shx cp ./config/config.js.${npm_config_env} ./config/config.js",
    "prestart": "npm install && npm run css",
    "start": "node app.js",
    "css": "node-sass -o public/styles public/styles",
    "css:watch": "npm run css -- -w",
    "web-scss": "concurrently \"npm run css:watch\" \"npm run start\""
  },
  "repository": {
    "type": "git",
    "url": "ssh://snc.uns@gmail.com@source.developers.google.com:2022/p/hi-homepage/r/hi-homepage-web-allnew"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "bootstrap": "^5.3.3",
    "braces": "^3.0.3",
    "concurrently": "^8.2.2",
    "cpx": "^1.5.0",
    "cross-env": "^7.0.3",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.0",
    "glob-parent": "^5.1.1",
    "http-proxy-middleware": "^3.0.0",
    "jquery": "^3.7.1",
    "moment": "^2.30.1",
    "node-sass": "^9.0.0",
    "path": "^0.12.7",
    "shx": "^0.3.4",
    "swiper": "^11.1.3",
    "tough-cookie": "^4.1.2",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "overrides": {
    "braces": "$braces",
    "glob-parent": "$glob-parent",
    "tough-cookie": "$tough-cookie"
  },
  "volta": {
    "node": "16.20.2",
    "npm": "8.19.4"
  }
}
